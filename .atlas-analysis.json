  "keyFeatures": [
    "Backwards compatibility with QB resources via bridge layer",
    "Built-in multicharacter system",
    "Multi-job and multi-gang support",
    "Queue system for full servers",
    "Persistent player vehicles",
    "Export-based API",
    "Optional modules: Hooks, Logger, Lib utilities",
    "Comprehensive admin commands",
    "Discord and Ox logger integration"
  ],
  "publicApiSurface": [
    "exports.qbx_core:Login(source, citizenid, newData)",
    "exports.qbx_core:GetOfflinePlayer(citizenid)",
    "exports.qbx_core:SetJob(identifier, jobName, grade)",
    "exports.qbx_core:SetGang(identifier, gangName, grade)",
    "exports.qbx_core:GetPlayer(source)",
    "exports.qbx_core:GetPlayerByCitizenId(citizenid)",
    "exports.qbx_core:GetPlayers()",
    "exports.qbx_core:registerHook(event, callback)",
    "exports.qbx_core:removeHooks(hookId)",
    "/tp - Teleport command",
    "/tpm - Teleport to marker",
    "/setjob - Set player job",
    "/setgang - Set player gang",
    "/giveitem - Give item to player",
    "/car - Spawn vehicle"
  ]
